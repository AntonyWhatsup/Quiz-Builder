datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Quiz {
  id        String     @id @default(uuid())
  title     String
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id      String @id @default(uuid())
  text    String
  type    String // "BOOLEAN", "INPUT", "CHECKBOX"
  options String? // JSON string for multiple choices
  quiz    Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId  String
}